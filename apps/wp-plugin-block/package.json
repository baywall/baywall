{
  "name": "@serendipity/wp-plugin-block",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "prebuild": "graphql-codegen",
    "build": "run-s build:*",
    "// この`i18n`コマンドは間接的に`wp-env run cli wp 18n`コマンドを呼び出します。": "",
    "// そのため、`wp-env start`で起動されるcli実行用のコンテナが立ち上がっていない場合、失敗します。": "",
    "// `prepare`で`i18n`コマンドを実行すると高確率で失敗するので注意してください。": "",
    "build:i18n": "run-s i18n",
    "build:js": "wp-scripts build",
    "check": "run-p check:*",
    "check:cycles": "madge --circular --extensions ts,tsx src",
    "check:license": "license-checker --production --excludePrivatePackages --onlyAllow '0BSD;Apache-2.0 WITH LLVM-exception;BSD-2-Clause;BSD-3-Clause;CC0-1.0;CC-BY-3.0;GPL-2.0-or-later;ISC;MIT' > /dev/null",
    "clean": "run-p clean:*",
    "clean:coverage": "rm -rf coverage",
    "clean:js": "rm -rf build/*",
    "coverage": "bash ../../scripts/npm-scripts/coverage-jest.sh --coverageDirectory=coverage/jest",
    "dev": "run-s watch",
    "// wp-envの起動設定(--xdebug=)によってphpunitのテストは問題なく終了するがカバレッジレポートが出力されない、という状況になるため、": "",
    "// カバレッジレポートが出力されているかどうかのチェック処理を`postcoverage:php`に記述している。": "",
    "postcoverage:php": "test -f coverage/phpunit/index.html || exit 1",
    "premy-docker:start": "bash ./.devcontainer/development-internal/update-compose-network.sh",
    "my-docker:start": "bash ./.devcontainer/development-internal/start.sh",
    "export-license": "run-s export-license:*",
    "export-license:block": "export-license -o licenses/npm -m licenses/block.json",
    "format": "run-p format:*",
    "format:js": "run-s format:js:*",
    "format:js:eslint": "bash ../../scripts/npm-scripts/format-eslint.sh .",
    "format:js:prettier": "bash ../../scripts/npm-scripts/format-prettier.sh .",
    "i18n": "i18next-cli extract",
    "lint": "run-p lint:*",
    "// lint:css": "wp-scripts lint-style",
    "lint:js": "run-p lint:js:*",
    "lint:js:tsc": "bash ../../scripts/npm-scripts/lint-tsc.sh",
    "lint:js:eslint": "bash ../../scripts/npm-scripts/lint-eslint.sh .",
    "lint:js:prettier": "bash ../../scripts/npm-scripts/lint-prettier.sh .",
    "packages-update": "wp-scripts packages-update",
    "start:docker": "run-p env:start my-docker:start",
    "test": "bash ../../scripts/npm-scripts/test-jest.sh",
    "pretest:storybook": "storybook build",
    "test:storybook": "concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"http-server storybook-static --port 6006 --silent\" \" wait-on tcp:6006 && run-s test-storybook\"",
    "test-storybook": "test-storybook --url http://localhost:6006 --coverage --browsers firefox chromium",
    "storybook": "storybook dev -p 6006",
    "update:php-package": "cd includes && composer update",
    "update:package": "npx npm-check-updates -u --target minor",
    "prewatch": "run-s prebuild",
    "watch": "run-p watch:*",
    "watch:block": "wp-scripts start",
    "watch:graphql": "graphql-codegen --watch"
  },
  "# note": {
    "// - scripts": "",
    "//   - check:license: ": "",
    "//     - 'GPLv3'や'GPLv3 or later'はGPLv2と互換がないため指定不可": "",
    "//        ⇒ https://www.gnu.org/licenses/gpl-faq.ja.html#gpl-compat-matrix": "",
    "//     - 'Apache-2.0'はGPLv2と互換がないため指定不可": "",
    "//     - 'Apache-2.0 WITH LLVM-exception'は指定可": "",
    "//        ⇒ https://github.com/ccampbell/mousetrap/issues/421": "",
    "// - devDependencies: ": "",
    "//   - @wordpress/scripts": "",
    "//     - WordPress6.5以前を対象とする場合、はv27を使う必要がある ": "",
    "//       => https://github.com/WordPress/gutenberg/blob/d649865283aff3545f9754a01c92982e37602dc8/packages/scripts/CHANGELOG.md#breaking-changes-2": ""
  },
  "dependencies": {
    "@serendipity/lib-frontend": "workspace:*",
    "@serendipity/lib-value-object": "workspace:*",
    "@tanstack/react-query": "^5.97.0",
    "@wordpress/block-editor": "^15.16.0",
    "@wordpress/blocks": "^15.16.0",
    "@wordpress/components": "^32.5.0",
    "@wordpress/data": "^10.43.0",
    "@wordpress/editor": "^14.43.0",
    "@wordpress/element": "^6.43.0",
    "@wordpress/icons": "^12.1.0",
    "@wordpress/notices": "^5.43.0",
    "assert": "^2.1.0",
    "async-lock": "^1.4.1",
    "currency-codes": "^2.2.0",
    "fast-deep-equal": "^3.1.3",
    "graphql": "^16.13.1",
    "i18next": "^25.10.4",
    "i18next-browser-languagedetector": "8.2.1",
    "jotai": "^2.18.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "^16.6.0"
  },
  "devDependencies": {
    "@serendipity/export-license": "workspace:*"
  }
}
